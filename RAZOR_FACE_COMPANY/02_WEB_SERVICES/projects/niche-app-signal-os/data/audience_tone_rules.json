{
  "version": 2,
  "rules": {
    "gen_z_oshi_activity": {
      "description": "Z世代寄りの推し活層向け。説明口調や作り手目線を避け、現場あるある、あとで見返したい記録、散らばる情報への共感から入る。",
      "target_audience": "Z世代寄りの推し活層",
      "entry_style": "あるある",
      "tone": "短く自然。アプリ紹介ではなく、現場後に困る記録の散らばりへ共感する。",
      "use_words": [
        "現場",
        "見返す",
        "残す",
        "メモった",
        "散らばる",
        "あとで見たい",
        "座席",
        "セトリ",
        "遠征費",
        "グッズ",
        "思い出",
        "ログ",
        "どこいった",
        "写真フォルダ",
        "支払い履歴",
        "マジで",
        "詰む",
        "大散乱",
        "大捜索",
        "オタクあるある",
        "ぶっちゃけ"
      ],
      "avoid_words": [
        "管理",
        "効率化",
        "節約",
        "一元管理",
        "SaaS",
        "生産性",
        "革新的",
        "推し活女子",
        "完璧に整理",
        "試作UIを作ってます",
        "作ってます",
        "作りました",
        "管理できます",
        "節約しよう",
        "無駄遣い"
      ],
      "opening_style": [
        "あるあるからラフに入る",
        "アプリ説明から入らない",
        "作り手目線を出さない",
        "1文を短くする",
        "会話風の疑問を入れる",
        "盛りすぎた流行語ではなくオタクの雑談感に寄せる"
      ],
      "structure": [
        "推し活の記録が大散乱して詰むあるある",
        "座席、セトリ、遠征費、グッズなどを会話風に並べる",
        "あとで見返したいのにスクショと写真フォルダを大捜索する感覚",
        "現場ごとに一撃で残せるログの仮説",
        "Notionで事足りるか聞くCTA",
        "最後にリアルな意見を聞く"
      ],
      "cta_style": [
        "これ欲しい？",
        "これ使う？",
        "Notionで十分？",
        "専用であったら使う？"
      ],
      "max_lines": 9
    },
    "default_light_problem": {
      "description": "一般ニッチ向け。説明口調を避け、小さな困りごとへの共感から入る。",
      "target_audience": "小さな不便を感じる一般ユーザー",
      "entry_style": "あるある",
      "tone": "軽く自然。完成品の売り込みではなく、欲しいかどうかを聞く。",
      "use_words": [
        "あとで見返す",
        "散らばる",
        "メモ",
        "ログ",
        "これ欲しい"
      ],
      "avoid_words": [
        "革新的",
        "完全自動",
        "業務効率",
        "SaaS",
        "生産性"
      ],
      "opening_style": [
        "小さなあるあるから入る",
        "アプリ説明から入らない"
      ],
      "structure": [
        "小さな不便",
        "今の代替手段",
        "欲しいかどうかを聞くCTA"
      ],
      "cta_style": [
        "これ欲しい？",
        "今のやり方で十分？"
      ],
      "max_lines": 6
    }
  }
}
