{
  "version": 1,
  "rules": {
    "gen_z_oshi_activity": {
      "description": "Z世代/推し活向け。説明口調を避け、あるある・現場・見返す・残す文脈で投稿する。",
      "entry_style": "あるある",
      "tone": "軽い共感から入り、作り込みすぎず、試作UIとして聞く",
      "use_words": [
        "現場",
        "見返す",
        "残す",
        "メモった",
        "散らばる",
        "あとで見たい",
        "座席",
        "セトリ",
        "遠征費",
        "グッズ",
        "思い出",
        "ログ"
      ],
      "avoid_words": [
        "効率化",
        "管理しよう",
        "節約しよう",
        "無駄遣い",
        "課金しすぎ",
        "完璧に整理",
        "推し活女子",
        "革新的",
        "業務効率",
        "SaaS",
        "生産性"
      ],
      "structure": [
        "あるある共感",
        "散らばる情報の具体例",
        "現場ごとに残す試作UI",
        "Notionで十分か聞くCTA"
      ],
      "cta": "これ欲しい？それともNotionで十分？",
      "max_lines": 5
    },
    "default_light_problem": {
      "description": "一般ニッチ向け。説明しすぎず、小さい面倒の共感から入る。",
      "entry_style": "小さい面倒",
      "tone": "軽い問題提起と試作UIの相談",
      "use_words": [
        "あとで見返す",
        "散らばる",
        "メモ",
        "ログ",
        "試作UI"
      ],
      "avoid_words": [
        "革新的",
        "完全自動",
        "業務効率",
        "SaaS",
        "生産性"
      ],
      "structure": [
        "小さい面倒",
        "今の代替手段",
        "試作UI",
        "欲しいか聞くCTA"
      ],
      "cta": "これ欲しい？それとも今の管理で十分？",
      "max_lines": 5
    }
  }
}
